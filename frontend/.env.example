# ============================================================
# QueryGen AI — Frontend Environment Variables
# ============================================================
# Copy this file to frontend/.env and set your backend URL.
# NEVER commit frontend/.env to version control.
# ============================================================

# Backend API base URL
# Local development:
VITE_API_BASE_URL="https://your-backend-service-name.onrender.com"

# Production (Render) — replace with your actual backend service URL:
# VITE_API_BASE_URL="https://querygen-backend.onrender.com"
