# ============================================================
# QueryGen AI - Backend Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control - it contains secrets.
# ============================================================

# Application Configuration
APP_NAME="QueryGen AI"
APP_ENV="development"

# LLM Configuration
# Primary LLM provider: "groq" or "gemini"
LLM_PROVIDER="groq"
GROQ_API_KEY="your-groq-api-key"
GEMINI_API_KEY="your-gemini-api-key-optional"

# Database Configuration - Neon PostgreSQL ONLY
DATABASE_URL="postgresql://username:password@ep-your-project-pooler.region.aws.neon.tech/database_name?sslmode=require"

# Qdrant Vector Database Configuration
QDRANT_URL="https://your-qdrant-cloud-url.qdrant.tech"
QDRANT_API_KEY="your-qdrant-api-key"
QDRANT_COLLECTION_NAME="querygen_schema"
QDRANT_EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# Query Execution Limits
DEFAULT_LIMIT="50"
MAX_ROWS="100"
QUERY_TIMEOUT_SECONDS="10"
MAX_RETRY_ATTEMPTS="2"
ALLOW_WRITE="false"

# JWT Authentication Configs
JWT_SECRET_KEY="replace-with-secure-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRY_MINUTES=1440

# Database Connection Encryption Key
CONNECTION_ENCRYPTION_KEY="replace-with-secure-fernet-key-32bytes"

