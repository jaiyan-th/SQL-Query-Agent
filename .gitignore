# ============================================================
# QueryGen AI — .gitignore
# ============================================================

# Environment Variables
.env
backend/.env
frontend/.env
.env.local
.env.*.local
backend/.env.local
frontend/.env.local

# Keep env templates
!.env.example
!frontend/.env.example
!backend/.env.example

# Node Dependencies & Build Outputs
node_modules/
frontend/node_modules/
frontend/dist/
dist/
build/
npm-debug.log*
yarn-debug.log*

# Python Artifacts & Environments
__pycache__/
*.pyc
*.py[cod]
*.so
.Python
.pytest_cache/
.venv/
venv/
backend/.venv/
backend/venv/
ENV/
env/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.coverage
htmlcov/

# Logs & System Files
*.log
.DS_Store
Thumbs.db

# IDE & Editor Configurations
.vscode/
.idea/
*.swp
*.swo
*~

# Database Safety Block List
*.db
*.db-*
*.sqlite
*.sqlite3
